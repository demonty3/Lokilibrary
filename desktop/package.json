{
  "name": "lokilibrary-desktop",
  "version": "0.0.1",
  "private": true,
  "description": "Electron wrapper for lokilibrary (Memory Palace).",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && electron .",
    "dev": "tsc && cross-env LOKILIBRARY_RENDERER_URL=http://localhost:5183 electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "koffi": "^2.10.0",
    "sqlite-vec": "^0.1.6",
    "steamworks.js": "^0.4.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "typescript": "^6.0.0"
  }
}
