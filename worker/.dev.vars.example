# Copy to worker/.dev.vars (gitignored) and fill in real values for local dev.
# CLAUDE.md: API keys NEVER live in the frontend. All AI calls go through here.

# --- Stage 1 provider selection ---
# "anthropic" (prod) or "local" (dev iteration via Ollama)
LLM_PROVIDER=anthropic

# --- Anthropic (prod) ---
# Required when LLM_PROVIDER=anthropic. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-

# Optional override. Default: claude-opus-4-7 (Stage 1 prod model per CLAUDE.md).
# ANTHROPIC_MODEL=claude-opus-4-7

# --- Local LLM (dev only — never ship to prod, per CLAUDE.md) ---
# Used only when LLM_PROVIDER=local.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:14b

# --- CORS ---
# Comma-separated list of allowed origins. Defaults cover localhost:5183 + 5173.
# ALLOWED_ORIGINS=http://localhost:5183,http://localhost:5173

# --- Steam (Phase 2) ---
# Required for v0.2. The OpenID handshake itself does NOT need this key — it
# becomes load-bearing at slice 2 when the worker calls GetOwnedGames /
# GetRecentlyPlayedGames / GetPlayerAchievements. Free at:
#   https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# HMAC secret for the session cookie. Generate something long and random, e.g.
#   openssl rand -base64 48
# Rotating it invalidates every existing session — fine in dev, plan in prod.
SESSION_SECRET=

# User-facing origin where the browser sees the app. In dev this is Vite
# (which proxies /api/* to the worker on :8787). In prod it's your deployed
# domain. Used to build the OpenID return_to / realm and cookie scope.
PUBLIC_BASE_URL=http://localhost:5183

# --- Steamworks SDK appid (Phase 6 slice 2) ---
# Appid the desktop wrapper's AuthSessionTickets are generated for. Must
# match desktop/steam_appid.txt — otherwise Steam Web API rejects ticket
# verification with "AppId mismatch". Defaults to 480 (SpaceWar) for dev;
# replace with your real appid after Steamworks partner approval.
STEAM_APP_ID=480
